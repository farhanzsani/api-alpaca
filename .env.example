# ============================================================
#  Alpaca API – Environment Variables
#  Copy file ini menjadi .env dan isi nilainya
# ============================================================

# PostgreSQL connection string
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
DATABASE_URL="postgresql://postgres:password@localhost:5432/alpaca_db?schema=public"

# Rahasia untuk JWT signing (ganti dengan string acak yang kuat di production)
JWT_SECRET="ganti-dengan-secret-yang-kuat"

# Environment
NODE_ENV="development"
